-->
<aura:component controller="Benefits_Ctr"
                implements="flexipage:availableForAllPageTypes,force:appHostable"
                access="global">

    <aura:attribute name="benefits" type="List" default="[]"/>
    <aura:attribute name="isLoading" type="Boolean" default="true"/>
    <aura:attribute name="errorMessage" type="String" default=""/>

    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>

    <div class="slds-card">
        <div class="slds-card__header slds-grid">
            <h2 class="slds-card__header-title slds-text-heading_small">
                Beneficios de Tarjetas de Crédito
            </h2>
        </div>

        <div class="slds-card__body slds-card__body_inner" style="overflow-x: auto; width: 100%;">

            <aura:if isTrue="{!v.isLoading}">
                <lightning:spinner alternativeText="Cargando..." size="medium"/>
            </aura:if>

            <aura:if isTrue="{!not(empty(v.errorMessage))}">
                <div class="slds-notify slds-notify_alert slds-alert_error">
                    <p>{!v.errorMessage}</p>
                </div>
            </aura:if>

            <aura:if isTrue="{!and(not(v.isLoading), empty(v.errorMessage))}">
                <aura:if isTrue="{!v.benefits.length > 0}">
                    <table class="slds-table slds-table_cell-buffer slds-table_bordered slds-table_striped"
                        style="min-width: 900px; width: max-content;">
                        <thead>
                            <tr class="slds-line-height_reset">
                                <th scope="col" style="min-width:130px; white-space:nowrap">
                                    <div>Nombre Tarjeta</div>
                                </th>
                                <th scope="col" style="min-width:80px; white-space:nowrap">
                                    <div>TEA (%)</div>
                                </th>
                                <th scope="col" style="min-width:70px; white-space:nowrap">
                                    <div>Millas</div>
                                </th>
                                <th scope="col" style="min-width:100px; white-space:nowrap">
                                    <div>CashBack (%)</div>
                                </th>
                                <th scope="col" style="min-width:110px; white-space:nowrap">
                                    <div>Cuota Anual</div>
                                </th>
                                <th scope="col" style="min-width:280px;">
                                    <div>Beneficios Adicionales</div>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <aura:iteration items="{!v.benefits}" var="benefit">
                                <tr>
                                    <td style="white-space:nowrap">{!benefit.CardName__c}</td>
                                    <td>{!benefit.AnnualEffectiveRate__c}</td>
                                    <td>{!benefit.MilesAccumulation__c}</td>
                                    <td>{!benefit.CashBackPercentage__c}</td>
                                    <td>{!benefit.AnnualFee__c}</td>
                                    <td>{!benefit.AdditionalBenefits__c}</td>
                                </tr>
                            </aura:iteration>
                        </tbody>
                    </table>

                    <aura:set attribute="else">
                        <div class="slds-align_absolute-center slds-p-around_medium">
                            <p class="slds-text-color_weak">No hay beneficios registrados.</p>
                        </div>
                    </aura:set>
                </aura:if>
            </aura:if>

        </div>
    </div>
</aura:component>